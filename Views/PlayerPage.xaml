<Page
    x:Class="MyMovie.Views.PlayerPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="Transparent">
    <Page.Resources>
        <AcrylicBrush x:Key="PlayerOverlayAcrylic"
                      TintColor="Black"
                      TintOpacity="0.5"
                      FallbackColor="#1A1A1A"/>
    </Page.Resources>

    <Grid Background="Black">
        <MediaPlayerElement x:Name="MainPlayer"
                    AreTransportControlsEnabled="True"
                    AutoPlay="True"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Stretch">
            <MediaPlayerElement.TransportControls>
                <MediaTransportControls IsCompact="False"
                               IsPlaybackRateButtonVisible="True"
                               IsPlaybackRateEnabled="True"
                               IsZoomButtonVisible="True"
                               IsZoomEnabled="True"/>
            </MediaPlayerElement.TransportControls>
        </MediaPlayerElement>

        <Button Click="Back_Click" 
                VerticalAlignment="Top" 
                HorizontalAlignment="Left" 
                Margin="20" 
                Background="{StaticResource PlayerOverlayAcrylic}" 
                Padding="12"
                CornerRadius="24"
                BorderThickness="1"
                BorderBrush="#33FFFFFF"
                Canvas.ZIndex="1">
            <FontIcon Glyph="&#xE72B;" Foreground="White" FontSize="18"/>
        </Button>
    </Grid>
</Page>