<Page
    x:Class="MyMovie.Views.MovieDetailsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:MyMovie.Models"
    mc:Ignorable="d"
    Background="Transparent">

    <Page.Resources>
        <AcrylicBrush x:Key="DetailAcrylic" TintColor="#1E1E1E" TintOpacity="0.7" FallbackColor="#2D2D2D"/>
    </Page.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">

        <StackPanel Padding="40" Spacing="30" MaxWidth="1200" HorizontalAlignment="Center">

            <StackPanel Orientation="Horizontal" Spacing="20" VerticalAlignment="Center">
                <Button Click="Back_Click" Background="Transparent" BorderThickness="0" Padding="8">
                    <FontIcon Glyph="&#xE72B;" FontSize="20"/>
                </Button>

            </StackPanel>

            <Grid ColumnDefinitions="400, *" ColumnSpacing="50">
                <StackPanel Grid.Column="0" Spacing="20">
                    <Border CornerRadius="20" Background="{ThemeResource SystemControlBackgroundAltHighBrush}" 
                            BorderBrush="#22FFFFFF" BorderThickness="1">
                        <Image Source="{x:Bind SelectedMovie.ThumbnailPath, Mode=OneWay}" 
                               Stretch="UniformToFill" Height="580"/>
                    </Border>
                </StackPanel>

                <Border Grid.Column="1" Background="{StaticResource DetailAcrylic}" 
                        Padding="35" CornerRadius="20" VerticalAlignment="Top">
                    <StackPanel Spacing="25">
                        <TextBlock Text="{x:Bind SelectedMovie.Title, Mode=OneWay}" 
                           FontSize="36" FontWeight="Bold" TextWrapping="Wrap"/>

                        <StackPanel Orientation="Horizontal" Spacing="15">
                            <Button Click="PlayMovie_Click" Style="{StaticResource AccentButtonStyle}" 
                                    Padding="30,12" CornerRadius="25">
                                <StackPanel Orientation="Horizontal" Spacing="12">
                                    <FontIcon Glyph="&#xE768;"/>
                                    <TextBlock Text="XEM PHIM" FontWeight="Bold"/>
                                </StackPanel>
                            </Button>

                            <Button x:Name="EditMovieButton" Click="EditMovie_Click" 
                                    Background="#F2994A" Foreground="White" 
                                    Padding="20,12" CornerRadius="25">
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <FontIcon Glyph="&#xE70F;"/>
                                    <TextBlock Text="Chỉnh sửa"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>

                        <MenuFlyoutSeparator Opacity="0.1"/>

                        <StackPanel Spacing="8" Orientation="Horizontal">
                            <TextBlock Text="ĐẠO DIỄN: " FontSize="12" FontWeight="Bold" Opacity="0.5" CharacterSpacing="100"/>
                            <TextBlock Text="{x:Bind SelectedMovie.Director, Mode=OneWay}" FontSize="15"/>
                        </StackPanel>

                        <StackPanel Spacing="8" Orientation="Horizontal">
                            <TextBlock Text="THỂ LOẠI: " FontSize="12" FontWeight="Bold" Opacity="0.5" CharacterSpacing="100"/>
                            <TextBlock Text="{x:Bind SelectedMovie.Genre, Mode=OneWay}" FontSize="15" FontStyle="Italic"/>
                        </StackPanel>

                        <StackPanel Spacing="8">
                            <TextBlock Text="NỘI DUNG" FontSize="12" FontWeight="Bold" Opacity="0.5" CharacterSpacing="100"/>

                            <Border Background="#1AFFFFFF" 
            Padding="15" 
            CornerRadius="10" 
            MaxHeight="150" 
            BorderThickness="1" 
            BorderBrush="#11FFFFFF">

                                <ScrollViewer VerticalScrollBarVisibility="Auto">
                                    <TextBlock Text="{x:Bind SelectedMovie.Description, Mode=OneWay}" 
                       TextWrapping="Wrap" 
                       FontSize="16" 
                       LineHeight="26" 
                       Opacity="0.9"/>
                                </ScrollViewer>
                            </Border>
                        </StackPanel>

                    </StackPanel>
                </Border>
            </Grid>
        </StackPanel>
    </ScrollViewer>
</Page>