<Page
    x:Class="MyMovie.Views.MovieDetailsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:MyMovie.Models"
    mc:Ignorable="d">

    <Grid Padding="40">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="245"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>



        <Border Grid.Column="0" CornerRadius="12" Height="350" VerticalAlignment="Top" 
                Background="{ThemeResource SystemControlBackgroundAltHighBrush}">
            <Image Source="{x:Bind SelectedMovie.ThumbnailPath, Mode=OneWay}" 
                   Stretch="UniformToFill"/>
        </Border>

        <StackPanel Grid.Column="1" Margin="40,0,0,0" Spacing="10">
            <TextBlock Text="{x:Bind SelectedMovie.Title, Mode=OneWay}" 
                       Style="{StaticResource TitleLargeTextBlockStyle}" 
                       FontSize="36" TextWrapping="Wrap"/>

            <StackPanel Orientation="Horizontal" Spacing="20">
                <TextBlock Text="{x:Bind SelectedMovie.Genre, Mode=OneWay}" 
                           Foreground="{ThemeResource SystemAccentColor}" 
                           FontWeight="Bold"/>
                <TextBlock Text="{x:Bind SelectedMovie.Director, Mode=OneWay}" 
                           Opacity="0.7" FontStyle="Italic"/>
            </StackPanel>

            <TextBlock Text="Mô tả nội dung" FontWeight="Bold" Margin="0,20,0,0"/>
            <TextBlock Text="{x:Bind SelectedMovie.Description, Mode=OneWay}" 
                       TextWrapping="Wrap" Opacity="0.8" LineHeight="24" MaxHeight="200"/>

            <Button Content="XEM PHIM" 
                    Click="PlayMovie_Click" 
                    Style="{StaticResource AccentButtonStyle}" 
                    Width="220" Height="50" 
                    Margin="0,30,0,0"
                    FontSize="18" FontWeight="Bold">
                <Button.ContentTemplate>
                    <DataTemplate>
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <FontIcon Glyph="&#xE768;"/>
                            <TextBlock Text="XEM PHIM"/>
                        </StackPanel>
                    </DataTemplate>
                </Button.ContentTemplate>
            </Button>
        </StackPanel>
    </Grid>
</Page>