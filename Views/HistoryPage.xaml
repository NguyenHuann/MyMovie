<Page
    x:Class="MyMovie.Views.HistoryPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:models="using:MyMovie.Models"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="Transparent">

    <Grid Padding="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Lịch Sử Xem Phim" 
                   FontSize="32" FontWeight="Bold" 
                   Margin="0,0,0,20"
                   Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>

        <StackPanel x:Name="EmptyState" 
                    Grid.Row="1" 
                    VerticalAlignment="Center" 
                    HorizontalAlignment="Center"
                    Visibility="Collapsed" 
                    Spacing="15">
            <FontIcon Glyph="&#xEB51;" FontSize="80" Opacity="0.2"/>
            <TextBlock Text="Bạn chưa xem bộ phim nào" 
                       FontSize="16" Opacity="0.5"/>
        </StackPanel>

        <GridView x:Name="MovieGrid"
                  Grid.Row="1"
                  ItemsSource="{x:Bind Movies}"
                  SelectionMode="None"
                  IsItemClickEnabled="True"
                  ItemClick="MovieGrid_ItemClick">

            <GridView.ItemTemplate>
                <DataTemplate x:DataType="models:Movie">
                    <Grid Width="180" Height="260" Margin="10"
                          PointerEntered="MovieItem_PointerEntered"
                          PointerExited="MovieItem_PointerExited"
                          Background="Transparent">

                        <Border CornerRadius="12" Background="#11FFFFFF">
                            <Image Source="{x:Bind ThumbnailPath}" Stretch="UniformToFill" />
                        </Border>

                        <Border CornerRadius="0,0,12,12" VerticalAlignment="Bottom" Height="80">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                    <GradientStop Color="Transparent" Offset="0"/>
                                    <GradientStop Color="#CC000000" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <TextBlock Text="{x:Bind Title}" 
                                       Foreground="White" FontWeight="SemiBold"
                                       FontSize="13" Margin="10,0,10,10"
                                       VerticalAlignment="Bottom"
                                       MaxLines="2" TextTrimming="CharacterEllipsis"/>
                        </Border>

                        <Border x:Name="HoverOverlay" CornerRadius="12" Background="#44000000" Opacity="0">
                            <Button HorizontalAlignment="Right" VerticalAlignment="Top" 
                                    Margin="8" Width="36" Height="36"
                                    Tag="{x:Bind}" Click="Unfavorite_Click"
                                    Style="{StaticResource DefaultButtonStyle}">
                                <FontIcon Glyph="&#xE74D;" FontSize="14" Foreground="White"/>
                            </Button>
                        </Border>
                    </Grid>
                </DataTemplate>
            </GridView.ItemTemplate>
        </GridView>
    </Grid>
</Page>