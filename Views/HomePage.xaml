<Page
    x:Class="MyMovie.Views.HomePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:MyMovie.Models"
    mc:Ignorable="d">
    <Page.Resources>
        <AcrylicBrush x:Key="ButtonAcrylicBackground"
                  TintColor="#2B2B2B"
                  TintOpacity="0.8"
                  FallbackColor="#1F1F1F"/>
    </Page.Resources>

    <Grid>
        <GridView x:Name="MovieGrid"
                  ItemsSource="{x:Bind Movies}"
                  Padding="0,0,0,80" 
                  SelectionMode="None"
                  IsItemClickEnabled="True"
                  ItemClick="MovieGrid_ItemClick">

            <GridView.ItemsPanel>
                <ItemsPanelTemplate>
                    <ItemsWrapGrid Orientation="Horizontal" MaximumRowsOrColumns="-1"/>
                </ItemsPanelTemplate>
            </GridView.ItemsPanel>

            <GridView.ItemTemplate>
                <DataTemplate x:DataType="models:Movie">
                    <Grid Width="180" Margin="10,10,10,10" Background="Transparent"
                          CornerRadius="8"
              PointerEntered="MovieItem_PointerEntered"
              PointerExited="MovieItem_PointerExited">

                        <Grid Width="180" Height="260">
                            <Border CornerRadius="8">
                                <Image Source="{x:Bind ThumbnailPath}" Stretch="UniformToFill"/>
                            </Border>

                            <Border CornerRadius="0,0,8,8" VerticalAlignment="Bottom">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                        <GradientStop Color="Transparent" Offset="0"/>
                                        <GradientStop Color="#CC000000" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>

                                <TextBlock Text="{x:Bind Title}" 
                               Foreground="White"
                               FontWeight="SemiBold"
                               FontSize="14"
                               Margin="10,20,10,10"
                               TextWrapping="Wrap"
                               MaxLines="2"
                               TextTrimming="CharacterEllipsis"
                               VerticalAlignment="Bottom"
                               HorizontalAlignment="Left"/>
                            </Border>

                            <Border x:Name="HoverOverlay" CornerRadius="8" Background="#99000000" Opacity="0">
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="8" Spacing="6">
                                    <Button Width="36" Height="36" Padding="0" 

                                CornerRadius="4"
                                Tag="{x:Bind}" 
                                Click="FavoriteButton_Click"
                                ToolTipService.ToolTip="Yêu thích">
                                        <FontIcon Glyph="&#xEB51;" 
                                                  FontSize="16"
                                                  Foreground="{x:Bind IsFavorite, Mode=OneWay, Converter={StaticResource FavoriteColorConverter}}"/>
                                        <Button.Resources>
                                            
                                            <SolidColorBrush x:Key="ButtonBackgroundPressed" Color="#66FFFFFF"/>
                                        </Button.Resources>
                                    </Button>

                                    <Button Width="36" Height="36" Padding="0" 

                                CornerRadius="4"
                                Tag="{x:Bind}" 
                                Click="DeleteButton_Click"
                                ToolTipService.ToolTip="Xóa phim">
                                        <FontIcon Glyph="&#xE74D;" FontSize="16"/>
                                        <Button.Resources>
                                            <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="#44FFFFFF"/>
                                            <SolidColorBrush x:Key="ButtonForegroundPointerOver" Color="#1B1B1C"/>

                                            <SolidColorBrush x:Key="ButtonBackgroundPressed" Color="#66FFFFFF"/>
                                        </Button.Resources>
                                    </Button>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </Grid>
                </DataTemplate>
            </GridView.ItemTemplate>
        </GridView>

        <StackPanel x:Name="EmptyState" 
                    VerticalAlignment="Center" 
                    HorizontalAlignment="Center"
                    Visibility="Collapsed" Spacing="10">
            <FontIcon Glyph="&#xE714;" FontSize="48" Opacity="0.5"/>
            <TextBlock Text="Thư viện của bạn đang trống" Opacity="0.7"/>
            <Button Content="Thêm phim ngay" Click="AddMovie_Click" HorizontalAlignment="Center"/>
        </StackPanel>

        <Button HorizontalAlignment="Right" 
                VerticalAlignment="Bottom" 
                Margin="32" Width="64" Height="64" 
                CornerRadius="32"
                Style="{StaticResource AccentButtonStyle}"
                Click="AddMovie_Click"
                ToolTipService.ToolTip="Thêm phim mới">
            <FontIcon Glyph="&#xE710;" FontSize="24"/>
            <Button.Shadow>
                <ThemeShadow />
            </Button.Shadow>
        </Button>
    </Grid>
</Page>