<Page
    x:Class="MyMovie.Views.FavoritesPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:models="using:MyMovie.Models"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="Transparent">
    <Page.Resources>
        <AcrylicBrush x:Key="ButtonAcrylicBackground"
                      TintColor="#2B2B2B"
                      TintOpacity="0.8"
                      FallbackColor="#1F1F1F"/>

    </Page.Resources>

    <Grid Padding="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Phim Yêu Thích" 
                   FontSize="32" 
                   FontWeight="Bold" 
                   Margin="0,0,0,10"
                   Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>

        <StackPanel x:Name="EmptyState" 
                    Grid.Row="1" 
                    VerticalAlignment="Center" 
                    HorizontalAlignment="Center"
                    Visibility="Collapsed" 
                    Spacing="15">
            <FontIcon Glyph="&#xEB51;" FontSize="80" Opacity="0.2"/>
            <TextBlock Text="Danh sách yêu thích đang trống" 
                       FontSize="16"
                       Opacity="0.5"/>
        </StackPanel>

        <GridView x:Name="MovieGrid"
                  Grid.Row="1"
                  ItemsSource="{x:Bind Movies}"
                  SelectionMode="None"
                  IsItemClickEnabled="True"
                  ItemClick="MovieGrid_ItemClick">

            <GridView.ItemsPanel>
                <ItemsPanelTemplate>
                    <ItemsWrapGrid Orientation="Horizontal" MaximumRowsOrColumns="-1"/>
                </ItemsPanelTemplate>
            </GridView.ItemsPanel>

            <GridView.ItemTemplate>
                <DataTemplate x:DataType="models:Movie">
                    <Grid Width="180"
                          Margin="10, 10, 10, 10" 
                          PointerEntered="MovieItem_PointerEntered"
                          PointerExited="MovieItem_PointerExited">

                        <Grid Width="180" Height="260">
                            <Border CornerRadius="12" Background="#11FFFFFF">
                                <Image Source="{x:Bind ThumbnailPath}" Stretch="UniformToFill" />
                            </Border>

                            <Border CornerRadius="0,0,8,8" VerticalAlignment="Bottom">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                        <GradientStop Color="Transparent" Offset="0"/>
                                        <GradientStop Color="#CC000000" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                                <TextBlock Text="{x:Bind Title}" 
                                           Foreground="White"
                                           FontWeight="SemiBold"
                                           FontSize="13"
                                           Margin="10,25,10,10"
                                           MaxLines="2"
                                           TextTrimming="CharacterEllipsis"/>
                            </Border>

                            <Border x:Name="HoverOverlay" CornerRadius="12" Background="#66000000" Opacity="0">
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="8">
                                    <Button Width="36" Height="36" Padding="0" 

                                CornerRadius="4"
                                Tag="{x:Bind}" 
                                Click="Unfavorite_Click"
                                ToolTipService.ToolTip="Yêu thích">
                                        <FontIcon Glyph="&#xEB51;" 
                                                  FontSize="16"
                                                  Foreground="{x:Bind IsFavorite, Mode=OneWay, Converter={StaticResource FavoriteColorConverter}}"/>
                                        <Button.Resources>

                                            <SolidColorBrush x:Key="ButtonBackgroundPressed" Color="#66FFFFFF"/>
                                        </Button.Resources>
                                    </Button>
                                </StackPanel>
                            </Border>
                        </Grid>
                    </Grid>
                </DataTemplate>
            </GridView.ItemTemplate>
        </GridView>
    </Grid>
</Page>