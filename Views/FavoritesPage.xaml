<Page
    x:Class="MyMovie.Views.FavoritesPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:models="using:MyMovie.Models"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Grid Padding="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Phim Yêu Thích" 
                   FontSize="28" 
                   FontWeight="Bold" 
                   Margin="0,0,0,20"/>

        <StackPanel x:Name="EmptyState" 
                    Grid.Row="1" 
                    VerticalAlignment="Center" 
                    HorizontalAlignment="Center"
                    Visibility="Collapsed">
            <FontIcon Glyph="&#xEB51;" FontSize="60" Foreground="Gray"/>
            <TextBlock Text="Danh sách yêu thích trống" 
                       Margin="0,10,0,0" 
                       Foreground="Gray"/>
        </StackPanel>

        <GridView x:Name="FavoriteMovieGrid"
                  Grid.Row="1"
                  ItemsSource="{x:Bind FavoriteMovies}"
                  IsItemClickEnabled="True"
                  ItemClick="MovieGrid_ItemClick">
            <GridView.ItemTemplate>
                <DataTemplate x:DataType="models:Movie">
                    <Grid Width="180" Margin="10" CornerRadius="8" Background="#222222">
                        <StackPanel>
                            <Image  Source="{x:Bind ThumbnailPath}" 
                                   Height="250" 
                                   Stretch="UniformToFill" 
                                   />

                            <TextBlock Text="{x:Bind Title}" 
                                       Margin="10" 
                                       FontWeight="SemiBold" 
                                       HorizontalAlignment="Center"
                                       MaxLines="1" 
                                       TextTrimming="CharacterEllipsis"/>
                        </StackPanel>

                        <Button Click="Unfavorite_Click" 
                                Tag="{x:Bind}"
                                VerticalAlignment="Top" 
                                HorizontalAlignment="Right" 
                                Margin="5"
                                Background="#66000000"
                                CornerRadius="20">
                            <FontIcon Glyph="&#xEB52;" Foreground="Red" FontSize="12"/>
                        </Button>
                    </Grid>
                </DataTemplate>
            </GridView.ItemTemplate>
        </GridView>
    </Grid>
</Page>