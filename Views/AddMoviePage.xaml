<Page
    x:Class="MyMovie.Views.AddMoviePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="Transparent">

    <Page.Resources>
        <AcrylicBrush x:Key="CardAcrylic"
                      TintColor="#1E1E1E" 
                      TintOpacity="0.8"
                      FallbackColor="#2D2D2D"/>
    </Page.Resources>

    <ScrollViewer>
        <StackPanel Padding="0" Spacing="10" MaxWidth="1200" HorizontalAlignment="Center">

            <StackPanel Spacing="5" HorizontalAlignment="Left">
                <TextBlock x:Name="PageTitle" Text="Thêm phim mới" FontSize="32" FontWeight="Bold"/>
                <TextBlock Text="Cập nhật bộ phim yêu thích của bạn vào thư viện cá nhân." Opacity="0.5"/>
            </StackPanel>

            <Grid ColumnDefinitions="450, 350" ColumnSpacing="40">
                <StackPanel Grid.Column="0" Spacing="20">
                    <Border Background="{StaticResource CardAcrylic}" 
        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
        BorderThickness="1" CornerRadius="16" Height="500">
                        <Grid x:Name="PosterGrid">
                            <StackPanel x:Name="UploadPlaceholder" Spacing="15" VerticalAlignment="Center">
                                <FontIcon Glyph="&#xE722;" FontSize="50" Opacity="0.4"/>
                                <Button Content="Chọn ảnh bìa phim" 
                    Click="PickPoster_Click"
                    HorizontalAlignment="Center"
                    Style="{StaticResource DefaultButtonStyle}"
                    CornerRadius="8"/>
                            </StackPanel>

                            <Grid x:Name="ImageSelectedContent" Visibility="Collapsed">
                                <Image x:Name="PosterPreview" Stretch="UniformToFill" Margin="1"/>

                                <Button Click="PickPoster_Click" 
                    VerticalAlignment="Bottom" 
                    HorizontalAlignment="Stretch"
                    Height="50"
                    Margin="0"
 
                    BorderThickness="0"
                    CornerRadius="0,0,10,10">
                                    <StackPanel Orientation="Horizontal" Spacing="10">
                                        <FontIcon Glyph="&#xE70F;" FontSize="16" Foreground="White"/>
                                        <TextBlock Text="Đổi ảnh bìa khác" Foreground="White"/>
                                    </StackPanel>
                                </Button>
                            </Grid>
                        </Grid>
                    </Border>
                    <TextBlock x:Name="PosterPathDisplay" FontSize="10" Opacity="0.3" TextWrapping="Wrap"/>

                    <Button Click="PickVideo_Click" Height="60" CornerRadius="10" HorizontalAlignment="Stretch">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <FontIcon Glyph="&#xE714;"/>
                            <TextBlock Text="Chọn tệp phim (.mp4, .mkv)"/>
                        </StackPanel>
                    </Button>
                    <TextBlock x:Name="VideoPathDisplay" FontSize="10" Opacity="0.3" TextWrapping="Wrap"/>
                </StackPanel>

                <Border Grid.Column="1" Background="{StaticResource CardAcrylic}"
                        Padding="30" CornerRadius="16" VerticalAlignment="Top">
                    <StackPanel Spacing="20">
                        <TextBox x:Name="TitleInput" Header="Tên phim" 
                                 PlaceholderText="Nhập tiêu đề bộ phim..."
                                 PlaceholderForeground="#66FFFFFF"/>

                        <TextBox x:Name="DirectorInput" Header="Đạo diễn" 
                                 PlaceholderText="Nhập tên đạo diễn..."
                                 PlaceholderForeground="#66FFFFFF"/>

                        <ComboBox x:Name="GenreInput" Header="Thể loại" HorizontalAlignment="Stretch" SelectedIndex="0">
                        </ComboBox>

                        <TextBox x:Name="DescInput" Header="Mô tả phim" 
                                 AcceptsReturn="True" Height="150" TextWrapping="Wrap"
                                 PlaceholderText="Kể câu chuyện về bộ phim này..."
                                 PlaceholderForeground="#66FFFFFF"/>

                        <Button x:Name="SaveBtn" Content="Lưu phim"
                                Click="SaveMovie_Click"
                                Height="50" CornerRadius="25" HorizontalAlignment="Stretch"
                                Style="{StaticResource AccentButtonStyle}"/>

                        <Button Content="Hủy bỏ" Click="Cancel_Click"
                                HorizontalAlignment="Stretch"
                                Height="50" CornerRadius="25"
                                BorderThickness="0" Opacity="0.6"/>
                    </StackPanel>
                </Border>
            </Grid>
        </StackPanel>
    </ScrollViewer>
</Page>