<Page
    x:Class="MyMovie.Views.AddMoviePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <ScrollViewer Padding="40">
        <StackPanel Spacing="20" MaxWidth="600" HorizontalAlignment="Left">
            <TextBlock Text="Thêm phim mới" Style="{StaticResource TitleTextBlockStyle}" Margin="0,0,0,10"/>

            <TextBox x:Name="TitleInput" Header="Tên phim" PlaceholderText="Nhập tên phim..."/>
            <TextBox x:Name="DirectorInput" Header="Đạo diễn" PlaceholderText="Nhập tên đạo diễn..."/>

            <ComboBox x:Name="GenreInput" Header="Thể loại" HorizontalAlignment="Stretch" PlaceholderText="Chọn thể loại">
                <x:String>Hành động</x:String>
                <x:String>Viễn tưởng</x:String>
                <x:String>Kinh dị</x:String>
                <x:String>Hài hước</x:String>
                <x:String>Tình cảm</x:String>
            </ComboBox>

            <TextBox x:Name="DescInput" Header="Mô tả phim" PlaceholderText="Nhập tóm tắt nội dung..." 
                     AcceptsReturn="True" Height="100" TextWrapping="Wrap"/>

            <MenuFlyoutSeparator/>

            <StackPanel Spacing="10">
                <TextBlock Text="Đường dẫn phim và Ảnh bìa" FontWeight="SemiBold"/>

                <Grid ColumnSpacing="10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="VideoPathDisplay" IsReadOnly="True" PlaceholderText="Chưa chọn tệp video..."/>
                    <Button Grid.Column="1" Content="Chọn Video" Click="PickVideo_Click" Style="{StaticResource AccentButtonStyle}"/>
                </Grid>

                <Grid ColumnSpacing="10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="PosterPathDisplay" IsReadOnly="True" PlaceholderText="Chưa chọn ảnh bìa..."/>
                    <Button Grid.Column="1" Content="Chọn Ảnh" Click="PickPoster_Click"/>
                </Grid>

                <Image x:Name="PosterPreview" Height="200" HorizontalAlignment="Left" Visibility="Collapsed" Margin="0,10,0,0"/>
            </StackPanel>

            <StackPanel Orientation="Horizontal" Spacing="10" Margin="0,20,0,0">
                <Button Content="Lưu phim" Click="SaveMovie_Click" Width="150" Style="{StaticResource AccentButtonStyle}"/>
                <Button Content="Hủy bỏ" Click="Cancel_Click" Width="100"/>
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</Page>