<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="MyMovie.Views.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <StackPanel Padding="40" Spacing="20">
        <TextBlock Text="Cài đặt" Style="{StaticResource TitleTextBlockStyle}"/>

        <Border Background="{ThemeResource SystemControlBackgroundAltHighBrush}" 
                Padding="20" CornerRadius="8">
            <StackPanel Spacing="10">
                <TextBlock Text="Cá nhân hóa" FontWeight="SemiBold"/>
                <TextBox x:Name="UserNameInput" 
                         Header="Tên người dùng" 
                         PlaceholderText="Nhập tên của bạn..." 
                         Width="300" HorizontalAlignment="Left"/>
                <Button Content="Lưu thay đổi" 
                        Click="SaveSettings_Click" 
                        Style="{StaticResource AccentButtonStyle}"
                        Margin="0,10,0,0"/>
            </StackPanel>
        </Border>

        <Border Background="{ThemeResource SystemControlBackgroundAltHighBrush}" 
                Padding="20" CornerRadius="8">
            <StackPanel Spacing="5">
                <TextBlock Text="Thông tin ứng dụng" FontWeight="SemiBold"/>
                <TextBlock Text="Phiên bản: 1.0.0 (BETA)" Opacity="0.7"/>
                <TextBlock Text="Nền tảng: .NET 8.0 + WinUI 3" Opacity="0.7"/>
            </StackPanel>
        </Border>
    </StackPanel>
</Page>