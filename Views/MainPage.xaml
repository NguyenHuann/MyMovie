<Page
    x:Class="MyMovie.Views.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Grid>
        <NavigationView x:Name="NavView" 
                        PaneDisplayMode="LeftCompact"
                        IsSettingsVisible="False"
                        IsBackButtonVisible="Visible" 
                        BackRequested="NavView_BackRequested"
                        SelectionChanged="NavView_SelectionChanged">

            <NavigationView.MenuItems>
                <NavigationViewItem Content="Trang chủ" Tag="home">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE80F;"/>
                    </NavigationViewItem.Icon>
                </NavigationViewItem>

                <NavigationViewItem Content="Yêu thích" Tag="favorites">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xEB51;"/>
                    </NavigationViewItem.Icon>
                </NavigationViewItem>

                <NavigationViewItem Content="Lịch sử" Tag="history">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE81C;"/>
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
            </NavigationView.MenuItems>

            <NavigationView.FooterMenuItems>
                <NavigationViewItem Content="Cài đặt" Tag="settings">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE713;"/>
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
            </NavigationView.FooterMenuItems>

            <Grid Padding="40,20,40,20">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <RelativePanel x:Name="HeaderPanel" Grid.Row="0" Margin="0,0,0,30">
                    <TextBlock x:Name="GreetingText" 
                               Text="đang tải..." 
                               FontSize="28"
                               FontWeight="SemiBold"
                               Style="{StaticResource TitleLargeTextBlockStyle}"/>

                    <StackPanel Orientation="Horizontal" 
                                RelativePanel.AlignRightWithPanel="True" 
                                Spacing="10">
                        <Button Width="40" Height="40" CornerRadius="20" Background="Transparent" ToolTipService.ToolTip="Tìm kiếm">
                            <FontIcon Glyph="&#xE721;" FontSize="16"/>
                        </Button>
                        <Button Width="40" Height="40" CornerRadius="20" Background="Transparent" ToolTipService.ToolTip="Sắp xếp">
                            <FontIcon Glyph="&#xE8CB;" FontSize="16"/>
                        </Button>
                    </StackPanel>
                </RelativePanel>

                <Frame x:Name="ContentFrame" 
                       Grid.Row="1" 
                       Navigated="ContentFrame_Navigated"/>
            </Grid>
        </NavigationView>
    </Grid>
</Page>